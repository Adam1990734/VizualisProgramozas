<UserControl x:Class="Beadandó_Adatbázis_Feladat.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Beadandó_Adatbázis_Feladat"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="SearchInput" Grid.Column="0"/>
        <ComboBox x:Name="ColumnChooser" Grid.Column="1"/>
        <Button x:Name="SearchBtn" Grid.Column="2">Keres</Button>
    </Grid>
</UserControl>
